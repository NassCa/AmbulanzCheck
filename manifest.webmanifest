<script>
function toggleNav(open) {
    const d = document.getElementById('nav-drawer');
    const o = document.getElementById('nav-overlay');
    const show = (open === undefined) ? !d.classList.contains('open') : open;
    d.classList.toggle('open', show);
    o.style.display = show ? 'block' : 'none';
}
document.addEventListener('DOMContentLoaded', () => {
    // Menü-Button in die Fortschrittsleiste einfügen
    const wrap = document.getElementById('progress-wrap');
    if (wrap) {
        const btn = document.createElement('button');
        btn.id = 'menu-btn';
        btn.textContent = '☰ Inhalt';
        btn.onclick = () => toggleNav();
        wrap.prepend(btn);
    }
    // Schnellzugriff-Chips unter der Leiste
    const chips = document.createElement('div');
    chips.id = 'quick-chips';
    chips.innerHTML =
        '<a class="chip-red" href="#page-13">⚠️ Notfall</a>' +
        '<a class="chip-blue" href="#page-12">📅 Quartal</a>' +
        '<a class="chip-blue" href="#page-14">🔄 Sitzung heute</a>' +
        '<a class="chip-blue" href="#page-8">❓ FAQ</a>' +
        '<a class="chip-blue" href="#page-9">📞 Kontakte</a>';
    if (wrap && wrap.parentNode) wrap.parentNode.insertBefore(chips, wrap.nextSibling);
    // Nach-oben-Button ab 600px Scroll
    window.addEventListener('scroll', () => {
        document.getElementById('to-top').style.display = window.scrollY > 600 ? 'block' : 'none';
    });
});
</script>

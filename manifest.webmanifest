<script>
// ===== Service Worker (Offline-Fähigkeit) =====
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('sw.js').catch(() => {});
  });
}

// ===== Häkchen dauerhaft speichern =====
const STORAGE_KEY = 'probatorik-checks';

function loadChecks() {
  let saved = {};
  try { saved = JSON.parse(localStorage.getItem(STORAGE_KEY)) || {}; } catch (e) {}
  document.querySelectorAll('.checklist-item input[type="checkbox"]').forEach((box, i) => {
    const key = box.id || 'cb' + i;
    if (saved[key]) box.checked = true;
    box.addEventListener('change', () => {
      saved[key] = box.checked;
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(saved)); } catch (e) {}
      updateProgress();
    });
  });
  updateProgress();
}

// ===== Fortschrittsanzeige =====
function updateProgress() {
  const boxes = document.querySelectorAll('.checklist-item input[type="checkbox"]');
  const done = [...boxes].filter(b => b.checked).length;
  const bar = document.getElementById('progress-bar');
  const label = document.getElementById('progress-label');
  if (bar && label) {
    const pct = boxes.length ? Math.round(done / boxes.length * 100) : 0;
    bar.style.width = pct + '%';
    label.textContent = done + ' / ' + boxes.length + ' (' + pct + '%)';
  }
}

function resetChecks() {
  if (!confirm('Alle Häkchen wirklich zurücksetzen?')) return;
  try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
  document.querySelectorAll('.checklist-item input[type="checkbox"]').forEach(b => b.checked = false);
  updateProgress();
}

// ===== Fortschrittsleiste oben einfügen (nur Bildschirm, nicht Druck) =====
document.addEventListener('DOMContentLoaded', () => {
  const barWrap = document.createElement('div');
  barWrap.id = 'progress-wrap';
  barWrap.innerHTML =
    '<div style="flex:1; background:#d0d0d0; border-radius:6px; height:12px; overflow:hidden;">' +
    '<div id="progress-bar" style="height:100%; width:0%; background:#1a73b8; transition:width .2s;"></div></div>' +
    '<span id="progress-label" style="font-size:12px; color:#333; min-width:90px; text-align:right;"></span>' +
    '<button onclick="resetChecks()" style="font-size:11px; padding:4px 10px; border:1px solid #1a73b8; background:white; color:#1a73b8; border-radius:4px; cursor:pointer;">Reset</button>';
  barWrap.style.cssText = 'position:sticky; top:0; z-index:10; display:flex; gap:10px; align-items:center; width:210mm; max-width:100%; margin:0 auto 10px auto; background:white; padding:8px 14px; box-shadow:0 1px 4px rgba(0,0,0,0.15); border-radius:6px;';
  document.body.prepend(barWrap);

  const style = document.createElement('style');
  style.textContent = '@media print { #progress-wrap { display: none !important; } }';
  document.head.appendChild(style);

  loadChecks();
});
</script>

<style>
/* ===== Navigation ===== */
#nav-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 90; display: none; }
#nav-drawer {
    position: fixed; top: 0; left: -290px; width: 280px; height: 100%;
    background: white; z-index: 100; box-shadow: 2px 0 12px rgba(0,0,0,0.25);
    transition: left .25s ease; overflow-y: auto; padding: 14px;
}
#nav-drawer.open { left: 0; }
#nav-drawer h2 { font-size: 15px; color: #1a73b8; margin: 0 0 10px 0; }
#nav-drawer .nav-group { font-size: 11px; font-weight: bold; color: white; background: #1a73b8; padding: 5px 9px; border-radius: 4px; margin: 12px 0 6px 0; }
#nav-drawer a { display: block; font-size: 12.5px; color: #333; text-decoration: none; padding: 7px 9px; border-radius: 4px; border-left: 3px solid transparent; }
#nav-drawer a:active, #nav-drawer a:hover { background: #e8f0f7; border-left-color: #1a73b8; }
#nav-drawer .pgnr { color: #999; font-size: 10px; }
#menu-btn { font-size: 12px; padding: 4px 10px; border: 1px solid #1a73b8; background: #1a73b8; color: white; border-radius: 4px; cursor: pointer; white-space: nowrap; }
#quick-chips { display: flex; gap: 6px; flex-wrap: wrap; width: 210mm; max-width: 100%; margin: 0 auto 10px auto; padding: 0 4px; }
#quick-chips a { font-size: 11.5px; padding: 6px 11px; border-radius: 14px; text-decoration: none; font-weight: bold; }
.chip-red { background: #fff3cd; color: #8b0000; border: 1px solid #ff6b6b; }
.chip-blue { background: #e3f2fd; color: #0d47a1; border: 1px solid #1a73b8; }
#to-top { position: fixed; right: 14px; bottom: 14px; z-index: 80; width: 42px; height: 42px; border-radius: 50%; border: none; background: #1a73b8; color: white; font-size: 19px; cursor: pointer; box-shadow: 0 2px 8px rgba(0,0,0,0.3); display: none; }
@media print { #nav-drawer, #nav-overlay, #quick-chips, #to-top { display: none !important; } }
html { scroll-behavior: smooth; }
</style>

